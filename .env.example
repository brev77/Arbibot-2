# Copy to `.env` at repo root and adjust. Dev Postgres/Redis: `docker compose -f infra/docker-compose.dev.yml up -d`
# Credentials below match infra/docker-compose.dev.yml (local development only).

# --- Shared data stores ---
# Dev compose maps Postgres to host port 15432 (see infra/docker-compose.dev.yml) to avoid clashing with a local Postgres on 5432.
DATABASE_URL=postgres://arbibot:arbibot@127.0.0.1:15432/arbibot
REDIS_URL=redis://127.0.0.1:6379

# --- Event bus (optional; start compose with `--profile bus`) ---
# KAFKA_BROKERS=127.0.0.1:19092

# --- HTTP security (Nest services via @arbibot/nest-platform) ---
# Production: set explicit browser origins (comma-separated). If unset in production, CORS is not enabled for browsers.
# CORS_ORIGINS=https://operator.example.com,https://operator.example.com:443
# Dev: when NODE_ENV is not production, defaults include http://localhost:3000 and :3001 if CORS_ORIGINS is empty.
# HTTP_RATE_LIMIT_MAX=300
# HTTP_RATE_LIMIT_WINDOW=1 minute

# --- apps/web: server-side BFF upstream (see apps/web/lib/api-base.ts) ---
# RISK_API_BASE=http://127.0.0.1:3000
# CONFIG_API_BASE=http://127.0.0.1:3019
# OPPORTUNITY_API_BASE=http://127.0.0.1:3010
# CAPITAL_API_BASE=http://127.0.0.1:3011
# EXECUTION_API_BASE=http://127.0.0.1:3012
# AUDIT_API_BASE=http://127.0.0.1:3013
# PORTFOLIO_API_BASE=http://127.0.0.1:3016
# RECONCILIATION_API_BASE=http://127.0.0.1:3017
# PAPER_API_BASE=http://127.0.0.1:3018
# MARKET_INTAKE_API_BASE=http://127.0.0.1:3015

# --- Nest: inter-service HTTP (not used by apps/web BFF) ---
# RISK_SERVICE_URL=http://127.0.0.1:3000

# --- risk-service: watchlist tiering + route scoring writers (PRIO-P2-TIER / PRIO-P2-SCORE) ---
# Background jobs (setInterval). Default off to avoid surprise timers in dev/CI:
# RISK_POLICY_JOBS_ENABLED=false
# WATCHLIST_TIERING_INTERVAL_MS=600000
# ROUTE_SCORING_INTERVAL_MS=3600000
# WATCHLIST_TIER_HOT_MIN_USD=1000000
# WATCHLIST_TIER_WARM_MIN_USD=100000
# ROUTE_SCORING_LOOKBACK_HOURS=24
# ROUTE_SCORING_NOTIONAL_REF_USD=5000000
# HTTP trigger for POST /policy/jobs/* (header x-arbibot-job-trigger). If unset, job endpoints return 503:
# RISK_POLICY_JOB_TRIGGER_TOKEN=change-me

# --- execution-orchestrator: peer HTTP reads (link-reservation / arm) ---
# Authoritative snapshots: capital-service and risk-service (not shared-table reads).
# CAPITAL_SERVICE_BASE_URL=http://127.0.0.1:3011
# RISK_SERVICE_BASE_URL=http://127.0.0.1:3000
# Aliases (orchestrator also accepts *_URL): CAPITAL_SERVICE_URL, RISK_SERVICE_URL
# D4-B-1-KILLSWITCH: config-service source of truth for dex.limits.killSwitch:
# CONFIG_SERVICE_URL=http://127.0.0.1:3019
# DEX_LIVE_KILL_SWITCH=true   # operator emergency halt (true|1) / explicit-allow (false|0)

# --- Operator web (apps/web) ---
# PORT=3000
# Signed JWT operator session (D4-A-1-AUTH). In non-production, unset values fall
# back to insecure dev defaults so local development works without configuration.
# Set these to exercise the real auth path locally:
# OPERATOR_SESSION_SECRET=dev-session-secret-min-32-bytes-long-xxxxx
# OPERATOR_BOOTSTRAP_TOKEN=dev-bootstrap-token
# OPERATOR_SESSION_TTL_SECONDS=28800
# ARBIBOT_DEV_ROLE=viewer
# Optional stable id for config-service audit when using cookies / production BFF:
# ARBIBOT_DEV_OPERATOR_ID=local-operator-1

# --- opportunity-service: paper discovery (PRIO-P2-PAPERDISC) ---
# Comma-separated instrument tokens; default BTC,ETH if unset:
# PAPER_DISCOVERY_INSTRUMENT_KEYS=BTC,ETH,SOL
# Poll interval ms; set 0 to disable periodic scan (e.g. CI):
# PAPER_DISCOVERY_POLL_MS=300000
# Shared secret for POST /opportunities/paper-discovery/run:
# PAPER_DISCOVERY_RUN_TOKEN=change-me

# --- paper-trading-service: discovery worker + config-service effective policy ---
# Base URL for config-service (same as CONFIG_API_BASE if unset). Used to load `paper.discovery` JSON.
# CONFIG_SERVICE_URL=http://127.0.0.1:3019
# Optional query params for GET .../paper.discovery/effective:
# PAPER_DISCOVERY_CONFIG_ENVIRONMENT=staging
# PAPER_DISCOVERY_CONFIG_TENANT_ID=
# Cache TTL (ms) for effective config; default 15000:
# PAPER_DISCOVERY_CONFIG_CACHE_MS=15000
# Fallback lists when effective is missing (comma-separated):
# PAPER_DISCOVERY_PAPER_ONLY_TOKENS=BTC,ETH
# PAPER_DISCOVERY_PAPER_ONLY_ROUTES=route-a,route-b
# PAPER_DISCOVERY_ENABLED=true
# PAPER_DISCOVERY_INTERVAL_MS=30000
# PAPER_DISCOVERY_MIN_PROFIT_USD=10
# PAPER_DISCOVERY_MIN_LIQUIDITY_SCORE=0.5
# PAPER_DISCOVERY_MAX_CANDIDATES_PER_RUN=50

# --- paper-trading-service: promotion gates (PRIO-P2-PROMO read model) ---
# PAPER_PROMOTION_MAX_DRIFT_BPS=50
# PAPER_PROMOTION_MIN_SCORE=

# --- Per-service ports when running Nest apps on host (defaults in each main.ts) ---
# config-service PORT=3019
# risk-service PORT=3000
# opportunity-service PORT=3010
# capital-service PORT=3011
# execution-orchestrator PORT=3012
# audit-service PORT=3013
# canonical-market-service PORT=3014
# market-intake-service PORT=3015
# Phase 4 intake throttling (ADR docs/adr-phase4-intake-throttling.md):
# INTAKE_THROTTLING_ENABLED=false
# INTAKE_POLICY_CACHE_TTL_MS=120000
# INTAKE_POLICY_HTTP_TIMEOUT_MS=8000
# CONFIG_SERVICE_URL=http://127.0.0.1:3019
# Optional scope for GET .../configurations/*/effective:
# INTAKE_CONFIG_ENVIRONMENT=staging
# INTAKE_CONFIG_TENANT_ID=

# --- hermes-gateway (Phase 5 read API + mutations + apps/web BFF proxy) ---
# Safe mode: shared Redis for multi-instance (same REDIS_URL as monorepo or dedicated):
# HERMES_SAFE_MODE_REDIS_URL=redis://127.0.0.1:6379
# HERMES_SAFE_MODE_USE_MEMORY_ONLY=true
# HERMES_SAFE_MODE_REDIS_TTL_SECONDS=0
# HERMES_GATEWAY_PORT=3020
# Comma-separated API keys for server-to-server calls (header x-hermes-api-key):
# HERMES_API_KEYS=dev-hermes-key-change-me
# Upstream bases for GET/POST /hermes/v1/* (defaults match local ports):
# EXECUTION_API_BASE=http://127.0.0.1:3012
# PORTFOLIO_API_BASE=http://127.0.0.1:3016
# RECONCILIATION_API_BASE=http://127.0.0.1:3017
# AUDIT_API_BASE=http://127.0.0.1:3013
# Next.js operator BFF base for GET /hermes/v1/dashboard/summary (stitched summary):
# OPERATOR_WEB_BFF_BASE=http://127.0.0.1:3000
# Mutation rate limit (fixed window per API key): max requests per window; set ENABLED=false to disable:
# HERMES_MUTATION_RATE_LIMIT_ENABLED=true
# HERMES_MUTATION_RATE_LIMIT_MAX=60
# HERMES_MUTATION_RATE_LIMIT_WINDOW_MS=60000
# apps/web: proxy to gateway (server-side only — never expose key to the browser):
# HERMES_GATEWAY_URL=http://127.0.0.1:3020
# HERMES_BFF_API_KEY=dev-hermes-key-change-me
# Legacy alias for the BFF key:
# HERMES_GATEWAY_API_KEY=dev-hermes-key-change-me

# --- hermes-agent (LLM = GLM 5.2 via Zhipu/Z.AI + личный Telegram-бот) ---
# Внешний агент NousResearch Hermes Agent. Ставится отдельно (см. tools/hermes-agent/README.md).
# GLM 5.2 подключается как OpenAI-совместимый провайдер (provider=openai + base_url):
# HERMES_LLM_PROVIDER=openai
# HERMES_LLM_MODEL=glm-5.2
# HERMES_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# HERMES_LLM_API_KEY=             # ключ из https://open.bigmodel.cn (никогда в git)
# Telegram (личный бот только для оператора — whitelist):
# HERMES_TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=             # токен от @BotFather в Telegram
# OPERATOR_TELEGRAM_ID=           # ваш Telegram ID (узнать у @userinfobot)
# MCP Server / Gateway (агент → MCP → gateway на 3020):
# HERMES_GATEWAY_URL=http://127.0.0.1:3020
# HERMES_API_KEY=dev-hermes-key-change-me
# HERMES_MCP_SERVER_PATH=../../packages/hermes-mcp-server/dist/index.js
# Периодические сводки в Telegram (агент «следит за ботом»):
# HERMES_CRON_ENABLED=true
# HERMES_MEMORY_PATH=./hermes-memory.db
# HERMES_LOG_LEVEL=info
# portfolio-service PORT=3016
# reconciliation-service PORT=3017
# paper-trading-service PORT=3018

# --- opportunity-service → paper-trading-service (optional Phase 3 discovery hook) ---
# POST /opportunities/:id/paper-enqueue writes outbox; OutboxRelayService delivers via HTTP when set.
# PAPER_TRADING_SERVICE_URL=http://127.0.0.1:3018
# Optional: max relay attempts for PaperPromotionCandidateRequested before dead-letter (default OUTBOX_RELAY_MAX_OPPORTUNITY_ATTEMPTS or 25).
# OUTBOX_RELAY_MAX_PAPER_PROMOTION_ATTEMPTS=25

# --- execution-orchestrator settlement (optional; Phase 2.1 FILL → portfolio → capital) ---
# When true, a full leg fill triggers HTTP confirm-fill on portfolio-service and, when all legs are filled, capital release.
# See docs/settlement-post-commit.md (retries, reconciliation, idempotency).
# Portfolio base URL: PORTFOLIO_SERVICE_URL if set, else PORTFOLIO_API_BASE (same as apps/web block above).
# Capital release base: CAPITAL_SERVICE_BASE_URL if set, else CAPITAL_SERVICE_URL, else default 127.0.0.1:3011.
# EXECUTION_SETTLEMENT_ENABLED=false
# CAPITAL_SERVICE_BASE_URL=http://127.0.0.1:3011
# CAPITAL_SERVICE_URL=http://127.0.0.1:3011
# Dev-only: fail portfolio confirm-fill for listed leg indexes (comma-separated) before HTTP; see docs/settlement-post-commit.md
# EXECUTION_SETTLEMENT_SIMULATE_PORTFOLIO_FAILURE_ON_LEG_INDEXES=

# --- HTTP venue (optional live TCP path; Phase 2.1 VEN) ---
# When set, execution-orchestrator uses HTTP POST `{base}/v1/submit-leg` instead of the in-process mock.
# Local lab server: `node tools/lab-venue-stand.mjs` (port `LAB_VENUE_PORT`, default 3099).
# VENUE_HTTP_BASE_URL=http://127.0.0.1:3099
# Hard cap for venue submit `fetch` (ms), clamped 1000–120000; avoids holding DB locks indefinitely.
# VENUE_HTTP_TIMEOUT_MS=12000
# Optional JSON map: classify 4xx by `venueErrorCode` from JSON body (per-venue semantics). Keys are `venueErrorCode` or `STATUS:venueErrorCode`.
# VENUE_HTTP_ERROR_CATEGORY_MAP={"404:UNKNOWN_LEG":"semantic","INSUFFICIENT_FUNDS":"semantic"}
# Real venue: endpoint must honor `submitIdempotencyKey` in JSON body (dedupe / same externalOrderId on replay).
# LAB_VENUE_PORT=3099

# --- Mock venue (execution-orchestrator tests / local chaos) ---
# Number of submitLeg failures to inject before succeeding (default 0).
# MOCK_VENUE_FAIL_SUBMIT_REMAINING=0
# Terminal submit for a specific leg index (non-retryable): rejected | timed_out | failed
# MOCK_VENUE_TERMINAL_LEG_INDEX=0
# MOCK_VENUE_TERMINAL_STATE=rejected

# --- execution-orchestrator: begin-execution leg fan-out (default 1) ---
# EXECUTION_BEGIN_LEG_COUNT=1

# --- execution-orchestrator: DEX gas policy (DEX-1-0-GAS) ---
# Max gas price in GWEI. Transactions exceeding this are rejected (unless GAS_REJECT_ON_EXCEED=false).
# MAX_GAS_PRICE_GWEI=50
# Max priority fee in GWEI (EIP-1559 maxPriorityFeePerGas cap).
# MAX_PRIORITY_FEE_GWEI=2
# Gas limit safety buffer multiplier (1.15 = 15% buffer above estimate).
# GAS_LIMIT_MULTIPLIER=1.15
# Set to 'false' to submit even when gas exceeds policy (not recommended for production).
# GAS_REJECT_ON_EXCEED=true
# Per-chain overrides: GAS_POLICY_{CHAINID}_MAX_FEE_GWEI / GAS_POLICY_{CHAINID}_MAX_PRIORITY_FEE_GWEI
# Example for Arbitrum (chain 42161):
# GAS_POLICY_42161_MAX_FEE_GWEI=100
# GAS_POLICY_42161_MAX_PRIORITY_FEE_GWEI=5

# --- execution-orchestrator: RPC providers (DEX-1-0-RPC) ---
# Primary RPC URLs per chain (required for DEX execution). Backup URLs enable failover.
# RPC_ARBITRUM_MAINNET_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARBITRUM_MAINNET_BACKUP_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_BACKUP_KEY
# RPC_ARBITRUM_TESTNET_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE_MAINNET_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE_MAINNET_BACKUP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_BACKUP_KEY
# RPC_BASE_TESTNET_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE_TESTNET_BACKUP_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_BACKUP_KEY
# RPC_BNB_MAINNET_URL=https://bsc-dataseed.binance.org
# RPC_BNB_MAINNET_BACKUP_URL=https://bsc-dataseed1.defibit.io
# RPC_BNB_TESTNET_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# --- Wallet management (DEX-1-0-VAULT / DEX-1-0-WALLET-MGT) ---
# ⚠️ SECURITY: Never commit real encryption keys. Use secrets manager in production.
# AES-256-GCM encryption key for wallet private keys (hex, 32 bytes = 64 chars).
# PRIVATE_KEY_ENCRYPTION_KEY=changeme-use-secrets-manager-in-prod
# Wallet selection strategy: round-robin | weighted | balance-based
# WALLET_SELECTION_STRATEGY=round-robin

# --- execution-orchestrator: DEX pool discovery (DEX-1-0-POOL-DISCOVERY) ---
# Enable periodic pool cache cleanup loop (default false):
# POOL_DISCOVERY_ENABLED=false
# Pool cache TTL in ms (default 300000 = 5 min):
# POOL_CACHE_TTL_MS=300000
# Pool cache cleanup interval ms (default 60000):
# POOL_DISCOVERY_INTERVAL_MS=60000

# --- execution-orchestrator: DEX risk policies (DEX-1-0-RISK-POLICIES) ---
# Max allowed slippage in basis points (default 100 = 1%):
# DEX_MAX_SLIPPAGE_BPS=100
# Max position size in USD per DEX trade (default 10000):
# DEX_MAX_POSITION_SIZE_USD=10000
# Min pool liquidity in USD (default 50000):
# DEX_MIN_POOL_LIQUIDITY_USD=50000
# Enable paper DEX on mainnet data stream (default false):
# PAPER_DEX_MAINNET_ENABLED=false
# Simulated gas used per swap (default 180000):
# PAPER_DEX_SIMULATED_GAS_USED=180000
# Simulated gas price in Gwei (default 0.1):
# PAPER_DEX_SIMULATED_GAS_PRICE_GWEI=0.1
# Output multiplier for scenario testing (default 1.0):
# PAPER_DEX_SIMULATED_OUTPUT_MULTIPLIER=1.0
# Price impact in bps (default 5 = 0.05%):
# PAPER_DEX_SIMULATED_PRICE_IMPACT_BPS=5

# --- execution-orchestrator: DEX live mainnet (DEX-1-3-LIVE-MAINNET) ---
# Master feature flag for live DEX execution (default false):
# DEX_LIVE_ENABLED=false
# Emergency kill switch — immediately stops all DEX trading (default false):
# DEX_LIVE_KILL_SWITCH=false
# Dry-run mode: sign but do not broadcast transactions (default true):
# DEX_LIVE_DRY_RUN=true
# Override max notional per trade in USD (overrides config-service dex.limits):
# DEX_LIVE_MAX_NOTIONAL_USD=500
# Override max gas price in GWEI (overrides config-service dex.limits):
# DEX_LIVE_MAX_GAS_PRICE_GWEI=30
# Require operator approval for each live trade (default true):
# DEX_LIVE_REQUIRE_APPROVAL=true

# --- E2E scripts ---
# Phase 1 chain; optional single-leg execution after arm.
# tools/e2e-phase1-foundation-chain.mjs — after arm(), also run begin-execution → mark-sent → ack → apply-fill (default off).
# E2E_INCLUDE_EXECUTION_LEG=false
# Phase 2 controlled execution (all legs, expects plan completed). See tools/e2e-phase2-controlled-execution.mjs
# npm run e2e:phase2-controlled-execution

# METRICS_ENABLED=true
# AUDIT_CLIENT_ENABLED=true

# --- OpenTelemetry (optional; P2-2.3-TRACE) ---
# When set, Nest services export traces via OTLP/HTTP (see docs/observability-tracing.md).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_SDK_DISABLED=true
# OTEL_TRACES_EXPORTER=none

# --- Structured logging (D4-C-1-LOGGING) ---
# All Nest services emit NDJSON via PinoLoggerService (@arbibot/nest-platform).
# Production emits NDJSON; non-production auto-pretty-prints for dev convenience.
# LOG_LEVEL=info                  # fatal|error|warn|info|debug|trace|silent
# ARBIBOT_LOG_PRETTY=false        # true → force pretty text even in production (debugging only)

