# Arbibot 2 — Next.js Operator Dashboard
# Usage (from monorepo root):
#   docker build -f infra/docker/Dockerfile.web \
#     -t ghcr.io/brev77/arbibot-web:latest .

# ── Stage 1: Prune ──────────────────────────────────────────────────
FROM node:26-alpine AS pruner
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY . .
RUN npx --yes turbo@2.9.5 prune @arbibot/web --docker

# ── Stage 2: Build ──────────────────────────────────────────────────
FROM node:26-alpine AS builder
WORKDIR /app
RUN apk add --no-cache libc6-compat

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/package-lock.json ./package-lock.json
RUN npm ci

COPY --from=pruner /app/out/full/ .

# Next.js collects anonymous telemetry — disable in CI/production
ENV NEXT_TELEMETRY_DISABLED=1

# Build-time env vars for Next.js (override at build time via --build-arg)
# These are baked into the client bundle; server-side BFF vars come from runtime env.
ARG NEXT_PUBLIC_APP_NAME=Arbibot

# Build shared packages that @arbibot/web depends on at build time
RUN npm run build -w @arbibot/contracts

RUN npm run build -w @arbibot/web

# ── Stage 3: Production runner ──────────────────────────────────────
FROM node:26-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

LABEL org.opencontainers.image.source="https://github.com/brev77/Arbibot-2"
LABEL org.opencontainers.image.title="arbibot-web"

RUN addgroup --system --gid 1001 arbibot && \
    adduser --system --uid 1001 -G arbibot arbibot

# Copy Next.js standalone output (if using output: 'standalone' in next.config)
# Fallback: copy full build artifacts
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

RUN chown -R arbibot:arbibot /app

USER arbibot
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO /dev/null http://localhost:3000/api/health || exit 1

CMD ["node", "apps/web/server.js"]