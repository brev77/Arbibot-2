{
  "annotations": { "list": [] },
  "description": "DEX Paper Mainnet — drift, success rate, latency, profit simulation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Paper Swap Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(arb_paper_dex_swap_total{status=\"success\"}[5m])",
          "legendFormat": "{{chain_id}} success",
          "refId": "A"
        },
        {
          "expr": "rate(arb_paper_dex_swap_total{status=\"error\"}[5m])",
          "legendFormat": "{{chain_id}} error",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops/s" },
        "overrides": []
      }
    },
    {
      "title": "Paper Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "rate(arb_paper_dex_swap_total{status=\"success\"}[5m]) / rate(arb_paper_dex_swap_total[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.95,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      }
    },
    {
      "title": "Paper Latency P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(arb_paper_dex_swap_latency_seconds_bucket[5m]))",
          "legendFormat": "{{chain_id}} p99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Simulated Gas Cost",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "arb_paper_dex_simulated_gas_cost_eth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ETH", "decimals": 8 }
      }
    },
    {
      "title": "Drift Median / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(arb_paper_dex_drift_bps_bucket[5m]))",
          "legendFormat": "{{chain_id}} median",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(arb_paper_dex_drift_bps_bucket[15m]))",
          "legendFormat": "{{chain_id}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(arb_paper_dex_drift_bps_bucket[1h]))",
          "legendFormat": "{{chain_id}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps" }
      }
    },
    {
      "title": "Drift Samples Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(arb_paper_dex_drift_samples_total[5m])",
          "legendFormat": "{{chain_id}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops/s" }
      }
    },
    {
      "title": "Simulated Profit/Loss",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "arb_paper_dex_simulated_profit_usd",
          "legendFormat": "{{chain_id}} {{venue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "USD" }
      }
    },
    {
      "title": "Drift by Route (Top 10)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, rate(arb_paper_dex_drift_bps_bucket[15m])))",
          "legendFormat": "{{route_key}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["arbibot", "dex", "paper-mainnet"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Arbibot DEX Paper Mainnet",
  "uid": "arb-dex-paper-mainnet"
}