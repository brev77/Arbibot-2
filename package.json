{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "arbibot-2",
  "private": true,
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "node tools/db-migrate.mjs",
    "db:verify-migrations": "node tools/verify-migrations-applied.mjs",
    "db:verify-migrations:all": "node tools/verify-migrations-applied.mjs --all",
    "e2e:phase1-foundation": "node tools/e2e-phase1-foundation-chain.mjs",
    "e2e:phase2-controlled-execution": "node tools/e2e-phase2-controlled-execution.mjs",
    "e2e:phase3-paper-promotion": "node tools/e2e-phase3-paper-promotion.mjs",
    "e2e:phase2-watchlist-route-scoring": "node tools/e2e-phase2-watchlist-route-scoring.mjs",
    "export:route-scoring-history": "node tools/export-route-scoring-history.mjs",
    "replay:route-scoring-export": "node tools/replay-route-scoring-export.mjs",
    "ci:e2e-phase2": "bash tools/ci-e2e-phase2.sh",
    "ci:e2e-phase3": "bash tools/ci-e2e-phase3-paper-promotion.sh",
    "ci:e2e-phase3-paper-discovery": "bash tools/ci-e2e-phase3-paper-discovery.sh",
    "ci:e2e-phase2-watchlist-route-scoring": "bash tools/ci-e2e-phase2-watchlist-route-scoring.sh",
    "e2e:phase4-tier-routing": "node tools/e2e-phase4-tier-routing.mjs",
    "ci:e2e-phase4-tier-routing": "bash tools/ci-e2e-phase4-tier-routing.sh",
    "seed:intake-policy-config": "node tools/seed-intake-policy-config.mjs",
    "ci:bus-smoke": "bash tools/ci-bus-smoke.sh",
    "seed:outbox-smoke-events": "node tools/seed-outbox-events.mjs",
    "seed:outbox-smoke-events:all": "node tools/seed-outbox-events.mjs all",
    "venue:load-test": "node tools/venue-load-test.mjs",
    "dex:load-test": "node tools/dex-load-test.mjs",
    "e2e:dex-testnet": "node tools/e2e-dex1-testnet.mjs",
    "e2e:dex2-multichain": "node tools/e2e-dex2-multichain.mjs",
    "dev:risk": "npm run start:dev -w @arbibot/risk-service",
    "dev:opportunity": "npm run start:dev -w @arbibot/opportunity-service",
    "dev:capital": "npm run start:dev -w @arbibot/capital-service",
    "dev:execution": "npm run start:dev -w @arbibot/execution-orchestrator",
    "dev:audit": "npm run start:dev -w @arbibot/audit-service",
    "dev:canonical": "npm run start:dev -w @arbibot/canonical-market-service",
    "dev:intake": "npm run start:dev -w @arbibot/market-intake-service",
    "dev:portfolio": "npm run start:dev -w @arbibot/portfolio-service",
    "dev:reconciliation": "npm run start:dev -w @arbibot/reconciliation-service",
    "dev:paper": "npm run start:dev -w @arbibot/paper-trading-service",
    "dev:config": "npm run start:dev -w @arbibot/config-service",
    "dev:web": "npm run dev -w @arbibot/web",
    "dev:hermes": "npm run start:dev -w @arbibot/hermes-gateway",
    "bus:publish": "npm run build -w @arbibot/outbox-kafka-bridge && npm run start:publish -w @arbibot/outbox-kafka-bridge",
    "bus:consume": "npm run build -w @arbibot/outbox-kafka-bridge && npm run start:consume -w @arbibot/outbox-kafka-bridge",
    "docker:build": "bash tools/docker-build-all.sh",
    "docker:push": "bash tools/docker-build-all.sh --push",
    "db:seed-canonical": "node tools/seed-canonical-registry.mjs",
    "db:backup": "bash tools/backup-postgres.sh",
    "verify:deployment": "bash tools/verify-deployment.sh",
    "verify:env": "bash tools/validate-env.sh",
    "generate:tls": "bash tools/generate-tls-certs.sh",
    "graphify:rebuild": "py -3 -c \"from graphify.watch import _rebuild_code; from pathlib import Path; _rebuild_code(Path('.'))\"",
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "graphify:query": "py -3 -m graphify query",
    "graphify:report": "type graphify-out\\GRAPH_REPORT.md"
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "^0.7.1",
    "ethers": "^6.13.0",
    "lucide-react": "^1.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/typeorm": "^11.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "pg": "^8.14.1",
    "turbo": "^2.9.5",
    "typeorm": "^0.3.27",
    "typescript-eslint": "^8.46.0"
  }
}
