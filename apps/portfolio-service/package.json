{
  "name": "@arbibot/portfolio-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsc -p tsconfig.build.json && concurrently -k -n tsc,node -c auto \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "test": "jest"
  },
  "dependencies": {
    "@arbibot/nest-database": "*",
    "@arbibot/nest-platform": "*",
    "@arbibot/persistence": "*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/typeorm": "^11.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.31"
  },
  "devDependencies": {
    "@arbibot/tsconfig": "*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": ["ts-jest", { "diagnostics": { "ignoreCodes": [151002] } }] },
    "collectCoverageFrom": ["**/*.ts", "!**/*.module.ts", "!**/*.dto.ts", "!**/*.interface.ts", "!**/*.type.ts", "!**/*.constant.ts", "!main.ts", "!**/index.ts"],
    "coverageDirectory": "../coverage",
    "testPathIgnorePatterns": ["/dist/", "/node_modules/"],
    "modulePathIgnorePatterns": ["<rootDir>/../dist"],
    "testEnvironment": "node"
  }
}