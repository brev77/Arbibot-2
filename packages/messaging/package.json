{
  "name": "@arbibot/messaging",
  "version": "0.0.1",
  "private": true,
  "description": "Outbox/inbox helpers (Phase 1.1-OIB)",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --config ../../eslint.config.mjs",
    "build": "tsc -p tsconfig.json",
    "test": "jest"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@arbibot/persistence": "*"
  },
  "peerDependencies": {
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@arbibot/tsconfig": "*",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typeorm": "^1.0.0",
    "typescript": "~5.9.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "testPathIgnorePatterns": ["/dist/", "/node_modules/"],
    "modulePathIgnorePatterns": ["<rootDir>/../dist"],
    "testEnvironment": "node"
  }
}