{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arbibot.local/schemas/plan-armed.payload.schema.json",
  "title": "PlanArmedPayloadV1",
  "type": "object",
  "required": [
    "planId",
    "state",
    "capitalReservationId",
    "entityVersion"
  ],
  "properties": {
    "planId": { "type": "string", "format": "uuid" },
    "state": { "type": "string", "const": "armed" },
    "capitalReservationId": { "type": "string", "format": "uuid" },
    "riskDecisionId": {
      "anyOf": [
        { "type": "string", "format": "uuid" },
        { "type": "null" }
      ]
    },
    "entityVersion": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
