# ═══════════════════════════════════════════════════════════════════
# Arbibot 2 — Production Environment Template
# Copy to .env and fill ALL values before deploying.
# DO NOT commit this file with real secrets.
# ═══════════════════════════════════════════════════════════════════

# ── Container registry ──────────────────────────────────────────
REGISTRY=ghcr.io/brev77
IMAGE_TAG=latest

# ── PostgreSQL ──────────────────────────────────────────────────
# ⚠️ Use a strong password (32+ chars). Store in secrets manager.
POSTGRES_USER=arbibot
POSTGRES_PASSWORD=<CHANGE_ME_USE_VAULT>
POSTGRES_DB=arbibot
DATABASE_URL=postgres://arbibot:${POSTGRES_PASSWORD}@pgbouncer:6432/arbibot
# Direct PostgreSQL (for migrations, admin):
# DATABASE_URL=postgres://arbibot:${POSTGRES_PASSWORD}@postgres:5432/arbibot

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka / Redpanda ────────────────────────────────────────────
KAFKA_BROKERS=redpanda:9092

# ── CORS (comma-separated browser origins) ──────────────────────
CORS_ORIGINS=https://operator.example.com

# ── HTTP rate limiting ──────────────────────────────────────────
HTTP_RATE_LIMIT_MAX=300
HTTP_RATE_LIMIT_WINDOW=1 minute

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_USE_VAULT>

# ── Inter-service URLs (Docker network names) ──────────────────
RISK_API_BASE=http://risk-service:3000
CONFIG_API_BASE=http://config-service:3019
OPPORTUNITY_API_BASE=http://opportunity-service:3010
CAPITAL_API_BASE=http://capital-service:3011
EXECUTION_API_BASE=http://execution-orchestrator:3012
AUDIT_API_BASE=http://audit-service:3013
PORTFOLIO_API_BASE=http://portfolio-service:3016
RECONCILIATION_API_BASE=http://reconciliation-service:3017
PAPER_API_BASE=http://paper-trading-service:3018
MARKET_INTAKE_API_BASE=http://market-intake-service:3015

RISK_SERVICE_URL=http://risk-service:3000
CAPITAL_SERVICE_BASE_URL=http://capital-service:3011
RISK_SERVICE_BASE_URL=http://risk-service:3000
PORTFOLIO_SERVICE_URL=http://portfolio-service:3016
CONFIG_SERVICE_URL=http://config-service:3019

# ── Settlement ──────────────────────────────────────────────────
EXECUTION_SETTLEMENT_ENABLED=true

# ── Operator web ────────────────────────────────────────────────
# Signed JWT operator session (D4-A-1-AUTH). The operator role is carried in a
# signed `arbibot_session` cookie (HS256), issued by POST /api/auth/session after
# verifying OPERATOR_BOOTSTRAP_TOKEN. Both secrets are REQUIRED in production —
# the app fails closed (503 / throw) if either is missing. Rotate the session
# secret to invalidate all active sessions.
OPERATOR_SESSION_SECRET=<CHANGE_ME_USE_VAULT>
OPERATOR_BOOTSTRAP_TOKEN=<CHANGE_ME_USE_VAULT>
# OPERATOR_SESSION_TTL_SECONDS=28800
#
# ⚠️ DO NOT set ARBIBOT_DEV_ROLE in production .env — env-fallback bypasses RBAC
#    middleware (see finding F4 in docs/pre-deploy-review.md). Role must come from
#    the signed `arbibot_session` cookie only.
# ARBIBOT_DEV_ROLE=operator
# ARBIBOT_DEV_OPERATOR_ID=

# ── Metrics / Observability ─────────────────────────────────────
METRICS_ENABLED=true
AUDIT_CLIENT_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Alertmanager paging (D4-A-2-PAGING) ─────────────────────────
# Rendered into infra/alertmanager/alertmanager.yml via envsubst at container
# start (see infra/docker/entrypoint.alertmanager.sh). At least ONE must be set
# for critical alerts to be paged; if both are empty, alertmanager falls back to
# an incidents-pipeline-only config (alerts appear in /incidents UI but are NOT
# paged). Configure before paper-deploy go-live.
# Slack incoming webhook for #arbibot-critical:
SLACK_WEBHOOK_URL=<CHANGE_ME_USE_VAULT>
# PagerDuty Events API v2 routing key (arbibot-critical schedule):
PAGERDUTY_ROUTING_KEY=<CHANGE_ME_USE_VAULT>
# ALERTMANAGER_SLACK_CHANNEL=#arbibot-critical

# ── Risk policy writers ────────────────────────────────────────
RISK_POLICY_JOBS_ENABLED=true
RISK_POLICY_JOB_TRIGGER_TOKEN=<CHANGE_ME_USE_VAULT>

# ── Paper trading ───────────────────────────────────────────────
PAPER_TRADING_SERVICE_URL=http://paper-trading-service:3018
PAPER_DISCOVERY_ENABLED=true
PAPER_DISCOVERY_INTERVAL_MS=30000

# ── HERMES gateway ──────────────────────────────────────────────
HERMES_GATEWAY_PORT=3020
HERMES_API_KEYS=<CHANGE_ME_USE_VAULT>
HERMES_GATEWAY_URL=http://hermes-gateway:3020
HERMES_BFF_API_KEY=<CHANGE_ME_USE_VAULT>
HERMES_SAFE_MODE_REDIS_URL=redis://redis:6379

# ── DEX (paper phase — keep disabled for initial deploy) ───────
DEX_LIVE_ENABLED=false
DEX_LIVE_KILL_SWITCH=true
DEX_LIVE_DRY_RUN=true
PAPER_DEX_MAINNET_ENABLED=false

# ── Service-to-service auth (D4-B-6-MTLS, finding L6) ─────────
# HMAC signature enforced by every backend service on inbound requests
# (fail-closed: misconfigured → 503 on all protected routes). REQUIRED for the
# live-gate — without it, any container on the arbibot-backend Docker network
# can call any service unauthenticated. Shared secret must be >=32 bytes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# See docs/adr-service-auth.md. Rotate by updating ARBIBOT_SERVICE_AUTH_SECRET
# on every backend service simultaneously (and any caller incl. hermes-gateway).
ARBIBOT_SERVICE_AUTH_ENABLED=true
ARBIBOT_SERVICE_AUTH_SECRET=<CHANGE_ME_USE_VAULT_64_HEX>
# When true, hermes-gateway signs its outbound upstream calls (its targets in
# live MUST be internal services only). Leave unset for dev/paper.
HERMES_SIGN_UPSTREAM=true

# ── Wallet / Key Vault (CRITICAL — use secrets manager) ────────
# Master AES-256-GCM key for encrypting wallet private keys at rest (wallet_keys
# table). Generate with: openssl rand -hex 32. NEVER commit a real value.
# Rotation requires re-encrypting every wallet_keys row with the new key — see
# docs/vault-integration-guide.md §6/§7. Phase C: superseded by Vault Transit.
PRIVATE_KEY_ENCRYPTION_KEY=<CHANGE_ME_USE_VAULT_64_HEX>

# ── Intake throttling ──────────────────────────────────────────
INTAKE_THROTTLING_ENABLED=true

# ── Venue (configure when connecting real venues) ──────────────
# VENUE_HTTP_BASE_URL=
# VENUE_HTTP_TIMEOUT_MS=12000