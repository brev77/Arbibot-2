# ═══════════════════════════════════════════════════════════════════
# Arbibot 2 — Production Environment Template
# Copy to .env and fill ALL values before deploying.
# DO NOT commit this file with real secrets.
# ═══════════════════════════════════════════════════════════════════

# ── Container registry ──────────────────────────────────────────
REGISTRY=ghcr.io/brev77
IMAGE_TAG=latest

# ── PostgreSQL ──────────────────────────────────────────────────
# ⚠️ Use a strong password (32+ chars). Store in secrets manager.
POSTGRES_USER=arbibot
POSTGRES_PASSWORD=<CHANGE_ME_USE_VAULT>
POSTGRES_DB=arbibot
DATABASE_URL=postgres://arbibot:${POSTGRES_PASSWORD}@pgbouncer:6432/arbibot
# Direct PostgreSQL (for migrations, admin):
# DATABASE_URL=postgres://arbibot:${POSTGRES_PASSWORD}@postgres:5432/arbibot

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka / Redpanda ────────────────────────────────────────────
KAFKA_BROKERS=redpanda:9092

# ── CORS (comma-separated browser origins) ──────────────────────
CORS_ORIGINS=https://operator.example.com

# ── HTTP rate limiting ──────────────────────────────────────────
HTTP_RATE_LIMIT_MAX=300
HTTP_RATE_LIMIT_WINDOW=1 minute

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_USE_VAULT>

# ── Inter-service URLs (Docker network names) ──────────────────
RISK_API_BASE=http://risk-service:3000
CONFIG_API_BASE=http://config-service:3019
OPPORTUNITY_API_BASE=http://opportunity-service:3010
CAPITAL_API_BASE=http://capital-service:3011
EXECUTION_API_BASE=http://execution-orchestrator:3012
AUDIT_API_BASE=http://audit-service:3013
PORTFOLIO_API_BASE=http://portfolio-service:3016
RECONCILIATION_API_BASE=http://reconciliation-service:3017
PAPER_API_BASE=http://paper-trading-service:3018
MARKET_INTAKE_API_BASE=http://market-intake-service:3015

RISK_SERVICE_URL=http://risk-service:3000
CAPITAL_SERVICE_BASE_URL=http://capital-service:3011
RISK_SERVICE_BASE_URL=http://risk-service:3000
PORTFOLIO_SERVICE_URL=http://portfolio-service:3016
CONFIG_SERVICE_URL=http://config-service:3019

# ── Settlement ──────────────────────────────────────────────────
EXECUTION_SETTLEMENT_ENABLED=true

# ── Operator web ────────────────────────────────────────────────
ARBIBOT_DEV_ROLE=operator
# ARBIBOT_DEV_OPERATOR_ID=

# ── Metrics / Observability ─────────────────────────────────────
METRICS_ENABLED=true
AUDIT_CLIENT_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Risk policy writers ────────────────────────────────────────
RISK_POLICY_JOBS_ENABLED=true
RISK_POLICY_JOB_TRIGGER_TOKEN=<CHANGE_ME_USE_VAULT>

# ── Paper trading ───────────────────────────────────────────────
PAPER_TRADING_SERVICE_URL=http://paper-trading-service:3018
PAPER_DISCOVERY_ENABLED=true
PAPER_DISCOVERY_INTERVAL_MS=30000

# ── OpenClaw gateway ────────────────────────────────────────────
OPENCLAW_GATEWAY_PORT=3020
OPENCLAW_API_KEYS=<CHANGE_ME_USE_VAULT>
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:3020
OPENCLAW_BFF_API_KEY=<CHANGE_ME_USE_VAULT>
OPENCLAW_SAFE_MODE_REDIS_URL=redis://redis:6379

# ── DEX (paper phase — keep disabled for initial deploy) ───────
DEX_LIVE_ENABLED=false
DEX_LIVE_KILL_SWITCH=true
DEX_LIVE_DRY_RUN=true
PAPER_DEX_MAINNET_ENABLED=false

# ── Wallet / Key Vault (CRITICAL — use secrets manager) ────────
# PRIVATE_KEY_ENCRYPTION_KEY=<64-char-hex-from-vault>

# ── Intake throttling ──────────────────────────────────────────
INTAKE_THROTTLING_ENABLED=true

# ── Venue (configure when connecting real venues) ──────────────
# VENUE_HTTP_BASE_URL=
# VENUE_HTTP_TIMEOUT_MS=12000