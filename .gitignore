node_modules/
dist/
build/

# npm workspaces: only the ROOT package-lock.json is committed.
# Per-workspace lockfiles (apps/*, packages/*) are stray artifacts from
# `npm install` run inside a subdirectory — they desync Dependabot and CI.
# The root lockfile is the single source of truth for `npm ci`.
apps/*/package-lock.json
packages/*/package-lock.json
.next/
.turbo/
coverage/
*.tsbuildinfo
.env
.env.*
!.env.example
!.env.production.example
*.log
.DS_Store
Thumbs.db

# graphify (local knowledge graph artifacts; not committed)
graphify-out/

# Production / deployment artifacts
backups/
*.sql.gz
infra/nginx/ssl/*.pem

# Local dev / scratch files (e.g. generator scripts output)
tools/_tmp
